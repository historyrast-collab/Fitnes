<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FitTrack - Modern Fitness</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #1a1a1a; color: white; margin: 0; display: flex; flex-direction: column; align-items: center; }
        header { background: linear-gradient(45deg, #4CAF50, #2E7D32); width: 100%; padding: 20px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        .container { padding: 20px; width: 90%; max-width: 500px; }
        .card { background: #2d2d2d; border-radius: 15px; padding: 20px; margin-bottom: 20px; border-left: 5px solid #4CAF50; }
        input, select { width: 100%; padding: 12px; margin: 10px 0; border-radius: 8px; border: none; background: #3d3d3d; color: white; box-sizing: border-box; }
        button { width: 100%; padding: 15px; background-color: #4CAF50; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        button:hover { background-color: #45a049; }
        .stats { display: flex; justify-content: space-between; margin-top: 20px; font-size: 0.9em; color: #aaa; }
    </style>
</head>
<body>
    <header><h1>FitTrack AI</h1></header>
    <div class="container">
        <div class="card">
            <h3>Antrenman Kaydet</h3>
            <select id="exercise">
                <option value="Şınav">Şınav</option>
                <option value="Mekik">Mekik</option>
                <option value="Squat">Squat</option>
                <option value="Koşu (dk)">Koşu (dk)</option>
            </select>
            <input type="number" id="reps" placeholder="Tekrar veya Süre Yaz">
            <button onclick="saveLog()">Kaydet</button>
        </div>
        <div id="logs"></div>
    </div>
    <script>
        function saveLog() {
            const ex = document.getElementById('exercise').value;
            const rep = document.getElementById('reps').value;
            if(!rep) return alert("Lütfen miktar girin!");
            const logDiv = document.getElementById('logs');
            const newLog = document.createElement('div');
            newLog.className = 'card';
            newLog.innerHTML = `<strong>${ex}</strong>: ${rep} adet/dk <br><span style="font-size:0.8em; color:#888">${new Date().toLocaleTimeString()}</span>`;
            logDiv.prepend(newLog);
            document.getElementById('reps').value = "";
        }
    </script>
</body>
</html>
